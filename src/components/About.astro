---
import { arteImperceptibleBook } from "../data/featured";
import { contentShell } from "../config/layout";
import type { Messages } from "../i18n/locales";

interface Props {
  messages: Messages;
}

const { messages: m } = Astro.props;
const a = m.about;
---

<section
  id="about"
  class="scroll-mt-28 border-t border-stone-800/95 bg-[#151312]"
  aria-labelledby="about-heading"
>
  <div class:list={[contentShell, "py-14 sm:py-16 lg:py-20"]}>
    <h2 id="about-heading" class="font-display text-[1.875rem] font-semibold tracking-tight text-[#fcf6ee]">
      {a.heading}
    </h2>
    <div class="mt-8 lg:grid lg:grid-cols-12 lg:gap-x-12 lg:gap-y-10 xl:gap-x-16">
      <div class="min-w-0 space-y-5 text-[0.9625rem] leading-[1.75] text-stone-400 lg:col-span-7">
        <p>
          {a.p1}
        </p>
        <p>
          {a.p2Lead}{" "}
          <strong class="font-semibold text-stone-200">{a.levanteBold}</strong>{" "}{a.levanteTrail}{" "}
          <strong class="font-semibold text-stone-200">{a.feverBold}</strong>{a.p2Trail}
        </p>
        <div class="space-y-4">
          <p>
            {a.challengeLead}{" "}
            <strong class="font-semibold text-stone-200">{a.challengeBold}</strong>
            {" "}{a.bookLead}{" "}
            <a
              class="font-semibold italic text-amber-200 underline decoration-amber-500/55 underline-offset-[3px] transition hover:text-amber-50"
              href={arteImperceptibleBook.amazonUrl}
              target="_blank"
              rel="noopener noreferrer"
              lang="es">{arteImperceptibleBook.titleShort}</a
            >.
          </p>
          <p class="rounded-md border border-stone-700/95 bg-[#141210]/90 px-[0.875rem] py-[0.6875rem] font-sans text-[0.85rem] leading-relaxed text-stone-500">
            {a.bookAside}<span set:html={a.bookSpanishNote} />{a.bookAsideAfter}
            {" "}{a.bookListing}{" "}
            <a
              class="font-semibold text-amber-200 underline decoration-amber-500/55 underline-offset-[3px] hover:text-[#fff7ed]"
              href={arteImperceptibleBook.amazonUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              Amazon.es&nbsp;<span aria-hidden="true">·</span> ISBN&nbsp;{arteImperceptibleBook.isbnDisplay}
            </a>
            <span aria-hidden="true">&nbsp;(↗)</span>.
          </p>
        </div>
      </div>

      <aside
        class="surface-muted rounded-lg p-6 lg:sticky lg:top-28 lg:col-span-5 lg:self-start xl:top-32"
        aria-label={a.asideEducation}
      >
        <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-stone-500">{a.asideEducation}</p>
        <p class="mt-4 text-[0.905rem] leading-relaxed text-stone-400">
          {a.eduDegree} ({a.eduSpec}),{" "}
          <strong class="font-medium text-stone-200">{a.eduSchool}</strong>
          {a.eduHonoursLead}{" "}<em class="text-stone-300">{a.eduProjectRef}</em>{" "}{a.eduProjectTrail}
        </p>
      </aside>
    </div>
  </div>
</section>
