---
import type { Project } from "../data/projects";

interface Props {
  project: Project;
}

const { project } = Astro.props;

const iconClass = "size-3.5 shrink-0 text-teal-300/95";
---

<article class="glass-card glass-card-hover flex flex-col overflow-hidden rounded-2xl">
  <a
    class="group/card relative block shrink-0 p-6 pb-5"
    href={project.primaryUrl}
    target="_blank"
    rel="noopener noreferrer"
  >
    <div class="relative z-10">
      {
        project.highlight ? (
          <p class="mb-3 inline-flex rounded-full bg-emerald-500/15 px-3 py-1 text-xs font-medium text-emerald-200 ring-1 ring-emerald-400/35">
            {project.highlight}
          </p>
        ) : null
      }
      <h3
        class="text-lg font-semibold tracking-tight text-white transition group-hover/card:text-teal-100"
      >
        {project.title}
      </h3>
      <p class="mt-2 text-sm leading-relaxed text-slate-400">
        {project.description}
      </p>
      <ul class="mt-4 flex flex-wrap gap-2" aria-hidden="true">
        {
          project.tags.map((tag) => (
            <li>
              <span class="rounded-full bg-white/5 px-2.5 py-0.5 text-[11px] font-medium text-slate-300 ring-1 ring-white/10">
                {tag}
              </span>
            </li>
          ))
        }
      </ul>
      <p class="sr-only">
        Opens the primary project destination in a new browser tab.
      </p>
      <span
        class="mt-6 inline-flex items-center gap-2 rounded-full bg-teal-400/15 px-4 py-2 text-xs font-semibold text-teal-100 ring-1 ring-teal-400/30 transition group-hover/card:bg-teal-400/25"
      >
        View project
        <svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M7 17L17 7M17 7H8M17 7V16" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </span>
    </div>
  </a>
  <div
    class="flex flex-shrink-0 flex-wrap items-center gap-3 border-t border-white/10 bg-slate-950/55 px-6 py-4"
  >
    <span class="text-[11px] font-semibold uppercase tracking-wider text-slate-500">
      More
    </span>
    <div class="flex flex-wrap gap-2">
      {
        project.links.map((link) => (
          <a
            class="glass-card hover:border-teal-400/35 inline-flex items-center gap-1.5 rounded-full px-3 py-1.5 text-xs font-medium text-slate-100 no-underline transition hover:text-white"
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
          >
            {
              link.icon === "demo" ? (
                <svg
                  class={iconClass}
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.85"
                  stroke="currentColor"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Z" />
                  <circle cx="12" cy="12" r="3" stroke-width="1.6" />
                </svg>
              ) : link.icon === "github" ? (
                <svg
                  class={`${iconClass} fill-teal-300/95`}
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path d="M12 2a10 10 0 0 0-3.17 19.52c.5.09.71-.21.71-.46v-1.6c-2.75.61-3.34-1.17-3.34-1.17-.46-1.16-1.1-1.47-1.1-1.47-.92-.61.06-.61.06-.61 1.01.06 1.54 1.04 1.54 1.04.92 1.53 2.38 1.09 2.96.82.09-.67.34-1.09.62-1.34-2.2-.25-4.53-1.13-4.53-4.93 0-1.08.39-2 1.03-2.7-.09-.26-.43-1.28.07-2.66 0 0 .82-.26 2.71 1.02a9.55 9.55 0 0 1 5 0c1.87-1.28 2.69-1.02 2.69-1.02.51 1.38.17 2.41.07 2.66.63.71 1.02 1.62 1.02 2.71 0 3.82-2.34 4.67-4.54 4.93.37.34.71.87.71 1.76v2.62c0 .26.21.54.71.46A10 10 0 0 0 12 2Z" />
                </svg>
              ) : link.icon === "video" ? (
                <svg
                  class={iconClass}
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.85"
                  stroke="currentColor"
                  aria-hidden="true"
                >
                  <rect x="7" y="7" width="9" height="10" rx="2" ry="2" stroke-linejoin="round" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="m17 11 4 3-4 3v-6Z" />
                </svg>
              ) : link.icon === "article" ? (
                <svg
                  class={iconClass}
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.85"
                  stroke="currentColor"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" d="M5 9h13M5 13h13M5 17h10" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10 22V7m3 15V11" />
                </svg>
              ) : link.icon === "linkedin" ? (
                <svg
                  class={`${iconClass} fill-teal-300/95`}
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path d="M20.45 20.45h-3.56v-5.62c0-1.34-.02-3.06-1.87-3.06-1.87 0-2.16 1.46-2.16 2.96v5.72H9.31V9h3.41v1.56h.05c.48-.92 1.64-1.87 3.39-1.87 3.62 0 4.29 2.39 4.29 5.49v6.27ZM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13Zm1.79 13.02H3.54V9h3.59v11.45ZM22.23 0H1.77C.79 0 0 .76 0 1.71v20.58C0 23.24.79 24 1.77 24h20.46C23.21 24 24 23.24 24 22.29V1.71C24 .76 23.21 0 22.23 0Z" />
                </svg>
              ) : (
                <span
                  class="size-3.5 shrink-0 rounded-[3px] bg-teal-300/65"
                  aria-hidden="true"
                />
              )
            }
            {link.label}
          </a>
        ))
      }
    </div>
  </div>
</article>
