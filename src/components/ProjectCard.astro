---
import type { Project } from "../data/projects";

interface Props {
  project: Project;
}

const { project } = Astro.props;

const iconClass =
  "size-3.5 shrink-0 text-amber-200/95";
---

<article class="surface-card surface-hover flex flex-col overflow-hidden rounded-lg">
  <a
    class="group/card relative flex shrink-0 flex-col px-7 pb-[1rem] pt-7 max-sm:px-5"
    href={project.primaryUrl}
    target="_blank"
    rel="noopener noreferrer"
  >
    {
      project.highlight ? (
        <p class="mb-3 inline-flex w-fit rounded-[3px] border border-amber-500/50 bg-[#2a2318] px-2.5 py-1 font-sans text-[11px] font-semibold uppercase tracking-[0.1em] text-amber-200/95">
          {project.highlight}
        </p>
      ) : null
    }
    <h3 class="font-display text-[1.2rem] font-semibold tracking-[-0.012em] text-[#fcf6ee] group-hover/card:text-[#fffaf3]">
      {project.title}
    </h3>
    <p class="font-sans mt-2.5 text-[0.9rem] leading-relaxed text-stone-500">
      {project.description}
    </p>
    <ul class="mt-4 flex flex-wrap gap-x-2 gap-y-2" aria-hidden="true">
      {
        project.tags.map((tag) => (
          <li>
            <span class="rounded-[2px] border border-stone-700/95 bg-[#141210] px-2 py-0.5 text-[11px] font-medium text-stone-400">
              {tag}
            </span>
          </li>
        ))
      }
    </ul>
    <p class="sr-only">
      Opens the primary project destination in a new browser tab.
    </p>
    <span
      class="font-sans mt-6 inline-flex w-fit items-center gap-2 border-b border-amber-500/85 pb-[2px] text-[13px] font-semibold text-amber-200/97 transition group-hover/card:border-amber-300 group-hover/card:text-[#fcefd9]"
    >
      Open linked work <span aria-hidden="true">&nbsp;↓</span>
    </span>
  </a>
  <div class="flex flex-shrink-0 flex-wrap items-start gap-x-10 gap-y-4 border-t border-stone-800 bg-[#181614] px-7 py-[0.92rem] max-sm:flex-col max-sm:px-5">
    <span class="pt-0.5 font-sans text-[11px] font-semibold uppercase tracking-[0.15em] text-stone-500">
      Also
    </span>
    <div class="flex min-w-0 flex-1 flex-wrap gap-2 font-sans">
      {
        project.links.map((link) => (
          <a
            class="rounded-[4px] border border-stone-700/98 bg-transparent px-[0.6rem] py-[0.375rem] text-[13px] font-medium text-stone-300 outline-none ring-amber-500/0 transition hover:border-stone-500 hover:bg-[#221f1d] hover:text-[#fcf6ee] focus-visible:ring-2"
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
          >
            <span class="inline-flex items-center gap-2">
              {
                link.icon === "demo" ? (
                  <svg
                    class={iconClass}
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.9"
                    stroke="currentColor"
                    aria-hidden="true"
                  >
                    <circle cx="12" cy="12" r="9" stroke-linecap="round" stroke-linejoin="round" />
                    <circle cx="12" cy="12" r="3" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                ) : link.icon === "github" ? (
                  <svg class={`${iconClass} fill-amber-200/95 stroke-none`} xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M12 2a10 10 0 0 0-3.17 19.52c.5.09.71-.21.71-.46v-1.6c-2.75.61-3.34-1.17-3.34-1.17-.46-1.16-1.1-1.47-1.1-1.47-.92-.61.06-.61.06-.61 1.01.06 1.54 1.04 1.54 1.04.92 1.53 2.38 1.09 2.96.82.09-.67.34-1.09.62-1.34-2.2-.25-4.53-1.13-4.53-4.93 0-1.08.39-2 1.03-2.7-.09-.26-.43-1.28.07-2.66 0 0 .82-.26 2.71 1.02a9.55 9.55 0 0 1 5 0c1.87-1.28 2.69-1.02 2.69-1.02.51 1.38.17 2.41.07 2.66.63.71 1.02 1.62 1.02 2.71 0 3.82-2.34 4.67-4.54 4.93.37.34.71.87.71 1.76v2.62c0 .26.21.54.71.46A10 10 0 0 0 12 2Z" />
                  </svg>
                ) : link.icon === "video" ? (
                  <svg class={iconClass} xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.9" stroke="currentColor" aria-hidden="true">
                    <rect x="7" y="7" width="9" height="10" rx="2" ry="2" stroke-linejoin="round" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="m17 11 4 3-4 3v-6Z" />
                  </svg>
                ) : link.icon === "article" ? (
                  <svg class={iconClass} xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.9" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" d="M5 9h13M5 13h13M5 17h10" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 22V7m3 15V11" />
                  </svg>
                ) : link.icon === "linkedin" ? (
                  <svg class={`${iconClass} fill-amber-200/95`} xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M20.45 20.45h-3.56v-5.62c0-1.34-.02-3.06-1.87-3.06-1.87 0-2.16 1.46-2.16 2.96v5.72H9.31V9h3.41v1.56h.05c.48-.92 1.64-1.87 3.39-1.87 3.62 0 4.29 2.39 4.29 5.49v6.27ZM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13Zm1.79 13.02H3.54V9h3.59v11.45ZM22.23 0H1.77C.79 0 0 .76 0 1.71v20.58C0 23.24.79 24 1.77 24h20.46C23.21 24 24 23.24 24 22.29V1.71C24 .76 23.21 0 22.23 0Z" />
                  </svg>
                ) : (
                  <span class="size-3 shrink-0 rounded-[2px] bg-amber-200/72" aria-hidden="true"></span>
                )
              }
              {link.label}
            </span>
          </a>
        ))
      }
    </div>
  </div>
</article>
