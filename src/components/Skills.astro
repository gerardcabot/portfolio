---
import { contentShell } from "../config/layout";
import type { Messages } from "../i18n/locales";

interface Props {
  messages: Messages;
}

const { messages: m } = Astro.props;
const s = m.skills;
---

<section id="skills" class="scroll-mt-28 py-14 sm:py-16 lg:py-20" aria-labelledby="skills-heading">
  <div class:list={[contentShell]}>
    <h2 id="skills-heading" class="font-display text-[1.875rem] font-semibold tracking-tight text-[#fcf6ee]">
      {s.heading}
    </h2>
    <p class="mt-4 max-w-3xl text-[0.9575rem] leading-relaxed text-stone-500">{s.intro}</p>
    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        s.groups.map((group) => (
          <div class="surface-muted rounded-lg p-[1rem_1rem_1.05rem] lg:col-span-1">
            <h3 class="text-[13px] font-semibold uppercase tracking-[0.08em] text-stone-500">{group.category}</h3>
            <ul class="mt-4 flex flex-wrap gap-2">
              {group.items.map((item) => (
                <li>
                  <span class="skill-chip">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>
