---
import { skillGroups } from "../data/skills";
---

<section id="skills" class="scroll-mt-28 px-4 py-14 sm:px-6 lg:py-20" aria-labelledby="skills-heading">
  <div class="mx-auto max-w-3xl">
    <h2 id="skills-heading" class="font-display text-[1.875rem] font-semibold tracking-tight text-[#fcf6ee]">
      Skills &amp; tooling
    </h2>
    <p class="mt-4 max-w-2xl text-[0.9575rem] leading-relaxed text-stone-500">
      Compressed snapshot of the CV stack and the tools that keep surfacing in shipping work — research spikes, Fever-scale backends, thesis code, and the earlier enterprise chapter.
    </p>
    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        skillGroups.map((group) => (
          <div class="surface-muted rounded-lg p-[1rem_1rem_1.05rem] lg:col-span-1">
            <h3 class="text-[13px] font-semibold uppercase tracking-[0.08em] text-stone-500">{group.category}</h3>
            <ul class="mt-4 flex flex-wrap gap-2">
              {group.items.map((item) => (
                <li>
                  <span class="rounded-[2px] border border-stone-700/95 bg-[#141210] px-2.5 py-1 text-[12.5px] font-medium tracking-tight text-stone-300">
                    {item}
                  </span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>
