---
import { skillGroups } from "../data/skills";
---

<section id="skills" class="scroll-mt-28 px-4 py-14 sm:px-6 lg:py-20" aria-labelledby="skills-heading">
  <div class="mx-auto max-w-3xl">
    <h2 id="skills-heading" class="font-display text-[1.875rem] font-semibold tracking-tight text-[#fcf6ee]">
      Skills &amp; tooling
    </h2>
    <p class="mt-4 max-w-2xl text-[0.9575rem] leading-relaxed text-stone-500">
      Taken almost verbatim from the CV grouping — pruned wherever it got too ornamental. If this drifts out of sync,{" "}
      <code class="rounded-sm border border-stone-700 bg-stone-950/80 px-1.5 py-0.5 text-[0.8375rem] text-amber-200/90">src/data/skills.ts</code>{" "}is where to edit.
    </p>
    <div class="mt-10 grid gap-6 sm:grid-cols-2">
      {
        skillGroups.map((group) => (
          <div class="surface-muted rounded-lg p-[1rem_1rem_1.05rem]">
            <h3 class="text-[13px] font-semibold uppercase tracking-[0.1em] text-stone-500">{group.category}</h3>
            <ul class="mt-4 flex flex-wrap gap-2">
              {group.items.map((item) => (
                <li>
                  <span class="rounded border border-stone-700/95 bg-[#141210] px-2.5 py-1 text-[12.5px] font-medium tracking-tight text-stone-300">
                    {item}
                  </span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>
