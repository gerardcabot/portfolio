---
import ProjectCard from "./ProjectCard.astro";
import { projects } from "../data/projects";
---

<section id="projects" class="scroll-mt-28 bg-[#151312]" aria-labelledby="projects-heading">
  <div class="mx-auto max-w-3xl px-4 py-14 sm:px-6 lg:py-[5.25rem]">
    <h2 id="projects-heading" class="font-display text-[1.875rem] font-semibold tracking-tight text-[#fcf6ee]">
      Projects
    </h2>
    <p class="mt-4 max-w-xl text-[0.9575rem] leading-relaxed text-stone-500">
      A couple of artefacts I still point recruiters to — one is coursework that shipped, one is a civic competition that
      still taught me volumes about metering series.
    </p>
    <div class="mt-10 grid gap-8 lg:gap-10">
      {
        projects.map((project) => (
          <ProjectCard project={project} />
        ))
      }
    </div>
  </div>
</section>
