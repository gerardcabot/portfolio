---
import { contentShell } from "../config/layout";
import type { Locale, Messages } from "../i18n/locales";
import { localeHash } from "../i18n/locales";

interface Props {
  messages: Messages;
  locale: Locale;
}

const { messages: m, locale } = Astro.props;
const h = m.hero;
---

<section
  id="top"
  class:list={[contentShell, "pb-16 pt-14 sm:pb-[5.5rem] sm:pt-[4.75rem]"]}
  aria-labelledby="hero-heading"
>
  <div class="grid gap-12 lg:grid-cols-12 lg:items-start xl:gap-x-16">
    <div class="min-w-0 lg:col-span-7 xl:col-span-7">
      <p
        class="animate-rise mb-8 text-[14px] font-medium leading-snug text-stone-400"
        style="animation-delay: 0ms"
      >
        {h.roles}
        <br />
        <span class="text-stone-500">{h.location}</span>
      </p>
      <div class="max-w-xl border-l-[3px] border-amber-500/85 pl-5 sm:max-w-none sm:pl-6 lg:max-w-2xl">
        <h1
          id="hero-heading"
          class="font-display text-[2.375rem] font-semibold tracking-[-0.02em] leading-[1.12] text-[#fcf6ee] sm:text-[2.875rem]"
          style="animation-delay: 50ms"
        >
          Gerard Cabot Agustín
        </h1>
        <p
          class="animate-rise mt-4 max-w-xl text-pretty text-[1.0625rem] leading-[1.62] text-stone-400 sm:max-w-2xl"
          style="animation-delay: 110ms"
        >
          {h.sub}
        </p>
        <div
          class="animate-rise mt-8 flex flex-wrap items-center gap-3 border-t border-stone-800/90 pt-6"
          style="animation-delay: 170ms"
        >
          <a
            class="rounded-md bg-amber-500 px-5 py-2.5 text-sm font-semibold text-[#171310] outline outline-1 outline-amber-500/95 transition hover:bg-amber-400"
            href={localeHash(locale, "projects")}>{h.ctaWork}</a
          >
          <a
            class="rounded-md border border-stone-600 px-5 py-2.5 text-sm font-medium text-stone-200 transition hover:border-amber-500/65 hover:bg-stone-900/85"
            href={localeHash(locale, "contact")}>{h.ctaContact}</a
          >
        </div>
      </div>
    </div>

    <aside
      aria-label={h.asideTitle}
      class="surface-muted animate-rise rounded-lg p-6 lg:sticky lg:top-28 lg:col-span-5 lg:self-start xl:top-32"
      style="animation-delay: 220ms"
    >
      <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-stone-500">{h.asideTitle}</p>
      <dl class="mt-5 space-y-4 border-t border-stone-700/85 pt-4 font-sans text-[0.89375rem] text-stone-400">
        <div>
          <dt class="text-[11px] font-semibold uppercase tracking-[0.1em] text-stone-500">{h.locationLabel}</dt>
          <dd class="mt-1 font-medium text-stone-200">{h.locationValue}</dd>
        </div>
        <div>
          <dt class="text-[11px] font-semibold uppercase tracking-[0.1em] text-stone-500">{h.languagesLabel}</dt>
          <dd class="mt-1 leading-snug text-stone-300">{h.languagesValue}</dd>
        </div>
        <div>
          <dt class="text-[11px] font-semibold uppercase tracking-[0.1em] text-stone-500">{h.focusLabel}</dt>
          <dd class="mt-1 leading-snug text-stone-300">
            {h.focusPlain}
          </dd>
        </div>
      </dl>
    </aside>
  </div>
</section>
