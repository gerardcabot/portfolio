---
import { contact } from "../data/contact";
---

<section
  id="contact"
  class="scroll-mt-28 px-4 py-16 sm:px-6 lg:pb-28 lg:pt-16"
  aria-labelledby="contact-heading"
>
  <div
    class="mx-auto max-w-5xl rounded-3xl border border-white/10 bg-linear-to-br from-teal-900/40 via-slate-900/60 to-emerald-900/35 p-[1px] shadow-xl shadow-teal-950/30"
  >
    <div
      class="rounded-[calc(theme(borderRadius.3xl)-1px)] bg-slate-950/95 px-6 py-10 sm:px-10"
    >
      <h2
        id="contact-heading"
        class="text-xs font-semibold uppercase tracking-[0.2em] text-teal-300/90"
      >
        Contact
      </h2>
      <p class="mt-3 max-w-2xl text-slate-300">
        Interested in collaborations, roles, or talking shop about data &
        engineering? Reach out on LinkedIn or explore my code on GitHub.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a
          class="glass-card glass-card-hover inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-medium text-white"
          href={contact.github}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub profile"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
            class="opacity-90"
          >
            <path
              d="M12 2C6.48 2 2 6.63 2 12.25c0 4.53 3.03 8.37 7.21 9.73.53.09.71-.23.71-.52 0-.25-.01-1.06-.02-1.92-3.01.65-3.63-1.29-3.63-1.29-.49-1.24-1.2-1.57-1.2-1.57-.97-.67.07-.66.07-.66 1.08.07 1.65 1.12 1.65 1.12.96 1.65 2.52 1.17 3.13.89.09-.71.37-1.17.67-1.44-2.4-.27-4.93-1.21-4.93-5.41 0-1.2.43-2.17 1.13-2.94-.11-.29-.49-1.44.11-3 0 0 .92-.3 3.02 1.12.88-.24 1.82-.37 2.76-.37.93 0 1.87.13 2.76.37 2.09-1.42 3.02-1.12 3.02-1.12.61 1.56.23 2.71.11 3 .71.76 1.13 1.74 1.13 2.94 0 4.21-2.53 5.13-4.93 5.41.39.34.73 1.01.73 2.03 0 1.46-.02 2.63-.02 2.98 0 .29.18.61.71.52C18.96 20.61 22 16.76 22 12.25 22 6.63 17.53 2 12 2Z"
            />
          </svg>
          GitHub
        </a>
        <a
          class="glass-card glass-card-hover inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-medium text-white"
          href={contact.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn profile"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M20.45 20.45h-3.56v-5.62c0-1.34-.02-3.06-1.87-3.06-1.87 0-2.16 1.46-2.16 2.96v5.72H9.31V9h3.41v1.56h.05c.48-.92 1.64-1.87 3.39-1.87 3.62 0 4.29 2.39 4.29 5.49v6.27ZM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13Zm1.79 13.02H3.54V9h3.59v11.45ZM22.23 0H1.77C.79 0 0 .76 0 1.71v20.58C0 23.24.79 24 1.77 24h20.46C23.21 24 24 23.24 24 22.29V1.71C24 .76 23.21 0 22.23 0Z"
            />
          </svg>
          LinkedIn
        </a>
        {
          contact.email ? (
            <a
              class="glass-card glass-card-hover inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-medium text-white"
              href={`mailto:${contact.email}`}
              aria-label="Email Gerard Cabot"
            >
              Email
            </a>
          ) : null
        }
      </div>
      <p class="mt-6 text-xs text-slate-500">
        Update links in{" "}
        <code class="text-teal-100/70">src/data/contact.ts</code>.
      </p>
    </div>
  </div>
</section>
