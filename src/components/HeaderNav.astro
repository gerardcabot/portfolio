---
import { contentShell } from "../config/layout";
import type { Locale, Messages } from "../i18n/locales";
import { locales, localeHash } from "../i18n/locales";

interface Props {
  locale: Locale;
  messages: Messages;
}

const { locale, messages } = Astro.props;
const n = messages.nav;

const localeHref = localeHash(locale, "top");

/** Short labels stay readable vs two-letter iso codes sitting alone */
const localeButtonClass =
  "inline-flex min-h-[30px] min-w-[2.75rem] items-center justify-center rounded-md border px-2 text-[12px] font-semibold transition sm:min-w-[2.85rem]";
---

<header class="sticky top-0 z-50 border-b border-stone-800/95 bg-[#121110]/90">
  <nav
    class:list={[contentShell, "flex flex-wrap items-end justify-between gap-4 py-4"]}
    aria-label={n.portfolio}
  >
    <div class="min-w-0">
      <a
        href={localeHref}
        class="font-display block text-[0.9375rem] font-semibold leading-tight tracking-tight text-[#fdf7ef]"
      >
        Gerard Cabot Agustín
      </a>
      <p class="mt-0.5 text-[11px] font-medium uppercase tracking-[0.12em] text-stone-500">{n.portfolio}</p>
      <div class="mt-3 flex max-w-[min(100%,22rem)] flex-col gap-1.5 sm:max-w-none">
        <p class="font-sans text-[11px] font-semibold uppercase tracking-[0.12em] text-stone-500">{n.langLabel}</p>
        <ul class="flex flex-wrap gap-x-1.5 gap-y-2 ps-0" role="list" aria-label={n.langLabel}>
          {
            locales.map((loc) =>
              loc === locale ? (
                <li class="contents">
                  <span
                    class:list={[
                      localeButtonClass,
                      "cursor-default border-amber-500/70 bg-[#261f18] text-amber-100",
                    ]}
                    aria-current="page"
                    title={loc}
                  >
                    {loc}
                  </span>
                </li>
              ) : (
                <li class="contents">
                  <a
                    class:list={[
                      localeButtonClass,
                      "border-stone-600/95 text-stone-300 hover:border-amber-500/70 hover:bg-stone-900/90 hover:text-[#fcf6ee]",
                    ]}
                    href={localeHash(loc, "top")}
                    lang={loc}
                  >
                    {loc}
                  </a>
                </li>
              ),
            )
          }
        </ul>
      </div>
    </div>
    <ul class="flex flex-wrap items-center gap-x-5 gap-y-1 text-[13px] font-medium leading-none text-stone-400 sm:justify-end sm:text-sm">
      <li>
        <a class="border-b border-transparent pb-px transition hover:border-amber-400/85 hover:text-stone-200" href={localeHash(locale, "about")}
          >{n.about}</a
        >
      </li>
      <li>
        <a class="border-b border-transparent pb-px transition hover:border-amber-400/85 hover:text-stone-200" href={localeHash(locale, "work")}
          >{n.experience}</a
        >
      </li>
      <li>
        <a class="border-b border-transparent pb-px transition hover:border-amber-400/85 hover:text-stone-200" href={localeHash(locale, "skills")}
          >{n.skills}</a
        >
      </li>
      <li>
        <a class="border-b border-transparent pb-px transition hover:border-amber-400/85 hover:text-stone-200" href={localeHash(locale, "projects")}
          >{n.projects}</a
        >
      </li>
      <li>
        <a class="border-b border-transparent pb-px transition hover:border-amber-400/85 hover:text-stone-200" href={localeHash(locale, "contact")}
          >{n.contact}</a
        >
      </li>
    </ul>
  </nav>
</header>
