---
import { contentShell } from "../config/layout";
import type { Locale, Messages } from "../i18n/locales";
import { localeChoices, locales, localeHash } from "../i18n/locales";

interface Props {
  locale: Locale;
  messages: Messages;
}

const { locale, messages } = Astro.props;
const n = messages.nav;

const localeHref = localeHash(locale, "top");

/** Active locale chip */
const localeActiveChip =
  "inline-flex flex-col gap-0.5 rounded-lg border px-4 py-2 text-left sm:flex-row sm:items-baseline sm:gap-3";
const localeInactiveChip =
  `${localeActiveChip} border-stone-500/95 bg-transparent text-stone-200 hover:border-amber-500/80 hover:bg-stone-800/95 hover:text-[#fcf6ee]`;

const localeCodeBadge = "font-mono text-[11px] font-bold uppercase tracking-tight text-amber-200/95";
---

<header class="sticky top-0 z-50">
  <div class="border-b border-amber-500/35 bg-linear-to-br from-[#2a261f] via-[#1f1c19] to-[#181614] shadow-[inset_0_1px_0_0_rgba(251,191,36,0.08)]">
    <div class:list={[contentShell, "flex flex-col gap-4 py-3.5"]}>
      <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
        <p class="font-sans text-[13px] font-bold uppercase tracking-[0.16em] text-amber-200/98">{n.langLabel}</p>
      </div>
      <nav class="flex flex-wrap gap-x-3 gap-y-2" aria-label={n.langLabel}>
        {
          locales.map((loc) => {
            const label = localeChoices[loc];

            return loc === locale ? (
              <span
                class:list={[localeActiveChip, "cursor-default border-amber-500/70 bg-[#362c22] shadow-sm"]}
                aria-current="page"
              >
                <span class={localeCodeBadge}>{loc}</span>
                <span class="font-sans text-sm font-semibold text-[#fcf6ee]">{label}</span>
              </span>
            ) : (
              <a href={localeHash(loc, "top")} class:list={[localeInactiveChip]} lang={loc}>
                <span class={localeCodeBadge}>{loc}</span>
                <span class="font-sans text-sm font-semibold">{label}</span>
              </a>
            );
          })
        }
      </nav>
    </div>
  </div>

  <div class="border-b border-stone-800/95 bg-[#121110]/95 backdrop-blur-sm supports-[backdrop-filter]:bg-[#121110]/88">
    <nav
      class:list={[contentShell, "flex flex-wrap items-end justify-between gap-4 pb-4 pt-4"]}
      aria-label={n.portfolio}
    >
      <div class="min-w-0">
        <a
          href={localeHref}
          class="font-display block text-[0.9375rem] font-semibold leading-tight tracking-tight text-[#fdf7ef]"
        >
          Gerard Cabot Agustín
        </a>
        <p class="mt-0.5 text-[11px] font-medium uppercase tracking-[0.12em] text-stone-500">{n.portfolio}</p>
      </div>
      <ul class="flex flex-wrap items-center gap-x-5 gap-y-2 text-[13px] font-medium leading-snug text-stone-400 sm:justify-end sm:text-sm">
        <li>
          <a class="border-b border-transparent pb-px transition hover:border-amber-400/85 hover:text-stone-200" href={localeHash(locale, "about")}
            >{n.about}</a
          >
        </li>
        <li>
          <a class="border-b border-transparent pb-px transition hover:border-amber-400/85 hover:text-stone-200" href={localeHash(locale, "work")}
            >{n.experience}</a
          >
        </li>
        <li>
          <a class="border-b border-transparent pb-px transition hover:border-amber-400/85 hover:text-stone-200" href={localeHash(locale, "skills")}
            >{n.skills}</a
          >
        </li>
        <li>
          <a class="border-b border-transparent pb-px transition hover:border-amber-400/85 hover:text-stone-200" href={localeHash(locale, "projects")}
            >{n.projects}</a
          >
        </li>
        <li>
          <a class="border-b border-transparent pb-px transition hover:border-amber-400/85 hover:text-stone-200" href={localeHash(locale, "contact")}
            >{n.contact}</a
          >
        </li>
      </ul>
    </nav>
  </div>
</header>
