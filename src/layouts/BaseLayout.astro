---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Gerard Cabot Agustín — Portfolio",
  description =
    "Gerard Cabot Agustín is a data scientist and software engineer focused on predictive modeling and football recruitment analytics — based in Barcelona, open to relocating.",
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Source+Serif+4:ital,wght@0,400..700;1,400..700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="relative bg-grain">
    <div class="fixed inset-x-0 top-0 z-0 h-[min(55vh,24rem)] bg-[radial-gradient(ellipse_at_50%_0,rgba(245,158,11,0.09),transparent_72%)]" aria-hidden="true"></div>
    <div class="pointer-events-none fixed bottom-[-10%] right-[-14%] z-0 h-[clamp(260px,38vw,480px)] w-[clamp(260px,38vw,480px)] rounded-full bg-stone-800/35 blur-[100px]" aria-hidden="true"></div>
    <slot />
  </body>
</html>
