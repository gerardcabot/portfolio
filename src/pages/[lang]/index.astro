---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { contentShell } from "../../config/layout";
import HeaderNav from "../../components/HeaderNav.astro";
import Hero from "../../components/Hero.astro";
import About from "../../components/About.astro";
import Experience from "../../components/Experience.astro";
import Skills from "../../components/Skills.astro";
import Projects from "../../components/Projects.astro";
import Contact from "../../components/Contact.astro";
import { locales, messagesByLocale, type Locale, type Messages } from "../../i18n/locales";

export function getStaticPaths() {
  return locales.map((lang) => ({
    params: { lang },
    props: { messages: messagesByLocale[lang] },
  }));
}

interface Props {
  messages: Messages;
}

const { messages } = Astro.props;

const locale = Astro.params.lang as Locale;
---

<BaseLayout locale={locale} messages={messages}>
  <HeaderNav locale={locale} messages={messages} />
  <main class="relative">
    <Hero messages={messages} locale={locale} />
    <About messages={messages} />
    <Experience messages={messages} />
    <Skills messages={messages} />
    <Projects messages={messages} />
    <Contact messages={messages} />
  </main>
  <footer class="border-t border-stone-800/95 py-[2.125rem]">
    <p class:list={[contentShell, "text-center font-sans text-[11px] leading-relaxed text-stone-600"]}>
      © {new Date().getFullYear()} Gerard Cabot Agustín — {messages.footer}
    </p>
  </footer>
</BaseLayout>
